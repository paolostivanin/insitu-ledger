<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Platform-level cleartext is permitted (self-hosters need LAN HTTP support
         and Android's domain-config has no CIDR for private ranges), but the actual
         HTTP gate is CleartextGuardInterceptor: it rejects all http:// requests
         unless the user explicitly opts in via Settings > "Allow HTTP (insecure)". -->
    <base-config cleartextTrafficPermitted="true" />
</network-security-config>
