<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Cleartext is allowed because self-hosted users typically connect to LAN servers
         over HTTP (e.g. http://192.168.1.x:8080). Android's domain-config does not
         support CIDR ranges, so restricting to private IPs is not feasible. -->
    <base-config cleartextTrafficPermitted="true" />
</network-security-config>
